// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 사용자 모델 정의
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("USER") // "USER" 또는 "ADMIN"
  status    String   @default("APPROVED") // "PENDING", "APPROVED", "REJECTED"
  createdAt DateTime @default(now())
  todos     Todo[]
}

// ToDo 아이템 데이터 모델 정의
model Todo {
  id          String   @id @default(cuid()) // 고유 식별자 (CUID)
  userId      String   // 연결된 사용자 외래 키
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // 할 일 제목 (공백 제외 최소 1자, 최대 50자)
  description String?  // 상세 설명 (선택)
  isCompleted Boolean  @default(false)      // 완료 상태 플래그
  priority    String   @default("MEDIUM")   // 우선순위 (HIGH | MEDIUM | LOW)
  category    String   @default("일반")     // 카테고리 태그 (기본값: '일반')
  dueDate     DateTime? // 마감 기한 (선택)
  createdAt   DateTime @default(now())      // 생성 일시
  updatedAt   DateTime @updatedAt          // 수정 일시
}

// 시스템 공지사항 데이터 모델
model SystemNotice {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 관리자 작업 감사 로그 데이터 모델
model AuditLog {
  id           String   @id @default(cuid())
  adminId      String
  adminEmail   String
  action       String   // 예: "USER_CREATE" | "USER_UPDATE" | "USER_DELETE" | "NOTICE_CREATE" | "NOTICE_DELETE"
  targetUserId String?
  details      String
  createdAt    DateTime @default(now())
}
